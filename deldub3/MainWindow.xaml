<Window x:Class="deldub3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:deldub3"
        mc:Ignorable="d"
        Title="deldub2" Height="250" Width="600">
    <Grid>
        <StackPanel Margin="15,10,15,10">

            <StackPanel Orientation="Horizontal">
                <Button Content="Выбрать папку и случайно переименовать файлы"
                        Click="Button_Click1"
                        Width="300" Height="25"
                        Margin="10,5,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Конвертировать все файлы в .jpg/.jpeg/.webp в .png"
                        Click="Button_Click23"
                        Width="300" Height="25"
                        Margin="10,5,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Выбрать папку и переименовать файлы"
                         Click="Button_Click4"
                        Width="300" Height="25"
                        Margin="10,5,0,0" />

                <CheckBox Name="prefZ"
                          Content="Учитывать Z***?"
                          Margin="10,9,10,0"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSelectFolder" 
                        Content="Выбрать папку и удалить дубликаты"
                        Click="Button_Click5"
                        Width="300" Height="25"
                        Margin="10,5,10,0" />

                <TextBox x:Name="TxtThreshold" Width="50" Text="99,5" Height="25" Margin="0,5,0,0"
                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                ToolTip="Введите процент от 0 до 100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSelectFolderToPath" 
                        Content="Удалить дубликаты из выбранной папки в папке"
                        Click="Button_Click6"
                        Width="300" Height="25"
                        Margin="10,5,10,0" />

                <TextBox x:Name="TxtThresholdToPath" Width="50" Text="99,5" Height="25" Margin="0,5,0,0"
                VerticalContentAlignment="Center" HorizontalContentAlignment= "Center"
                ToolTip="Введите процент от 0 до 100"/>
            </StackPanel>

            <ProgressBar x:Name="ProgressBarStatus"
                     Height="20" Minimum="0" Maximum="100"
                     Margin="0,20,0,0"/>

            <TextBlock x:Name="ProgressText"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   Text="Ожидание..."/>
        </StackPanel>
    </Grid>
</Window>
